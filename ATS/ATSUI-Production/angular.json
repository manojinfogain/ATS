{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": false
  },
  "version": 1,
  "newProjectRoot": "projects",
  "defaultProject": "ats-global-system",
  "projects": {
    "ats-global-system": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/ats-global-system",
      "sourceRoot": "projects/ats-global-system/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/ats-global-system",
            "resourcesOutputPath": "commons",
            "index": "projects/ats-global-system/src/index.html",
            "main": "projects/ats-global-system/src/main.ts",
            "polyfills": "projects/ats-global-system/src/polyfills.ts",
            "tsConfig": "projects/ats-global-system/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "allowedCommonJsDependencies":[
              "crypto-js",
              "xlsx",
              "moment-timezone",
              "clone-deep",
              "to-words"
            ],
            "assets": [
              "projects/ats-global-system/src/assets",
              "projects/ats-global-system/src/favicon.ico",
              "projects/ats-global-system/src/web.config",
              "projects/ats-global-system/src/config.ts",
            {
              "glob": "**/*",
              "input": "node_modules/ngx-extended-pdf-viewer/assets/",
              "output": "/assets/ngx-extended-pdf-viewer/"
            },
            {
              "glob": "**/*",
              "input": "node_modules/ngx-extended-pdf-viewer/bleeding-edge/",
              "output": "/bleeding-edge/"
            },
              {
                "glob": "**/*",
                "input": "projects/ats-lib/src/assets",
                "output": "/assets-lib/"
              }
            ],
            "styles": [
           "./node_modules/bootstrap/dist/css/bootstrap.min.css",
    "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",       
    "./node_modules/@angular/material/legacy-prebuilt-themes/legacy-indigo-pink.css",
    "./node_modules/font-awesome/css/font-awesome.css",
    "projects/ats-global-system/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5mb",
                  "maximumError": "10mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "100kb",
                  "maximumError": "1000kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/ats-global-system/src/environments/environment.ts",
                  "with": "projects/ats-global-system/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              }
            },
            "testing": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "10mb",
                  "maximumError": "15mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/ats-global-system/src/environments/environment.ts",
                  "with": "projects/ats-global-system/src/environments/environment.qa.ts"
                }
              ],
              "outputHashing": "all"
            },
            "staging": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/ats-global-system/src/environments/environment.ts",
                  "with": "projects/ats-global-system/src/environments/environment.uat.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "ats-global-system:build:production"
            },
            "development": {
              "browserTarget": "ats-global-system:build:development"
            },
            "testing": {
              "browserTarget": "ats-global-system:build:testing"
            },
            "staging": {
              "browserTarget": "ats-global-system:build:staging"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "ats-global-system:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/ats-global-system/src/test.ts",
            "polyfills": "projects/ats-global-system/src/polyfills.ts",
            "tsConfig": "projects/ats-global-system/tsconfig.spec.json",
            "karmaConfig": "projects/ats-global-system/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/ats-global-system/src/favicon.ico",
              "projects/ats-global-system/src/assets"
            ],
            "styles": [
              "projects/ats-global-system/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    },
    "ats-global-system-external": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/ats-global-system-external",
      "sourceRoot": "projects/ats-global-system-external/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/ats-global-system-external",
            "resourcesOutputPath": "commons",
            "index": "projects/ats-global-system-external/src/index.html",
            "main": "projects/ats-global-system-external/src/main.ts",
            "polyfills": "projects/ats-global-system-external/src/polyfills.ts",
            "tsConfig": "projects/ats-global-system-external/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "allowedCommonJsDependencies":[
              "crypto-js",
              "xlsx",
              "moment-timezone",
              "clone-deep"
            ],
            "assets": [
              "projects/ats-global-system-external/src/assets",
              "projects/ats-global-system-external/src/favicon.ico",
              "projects/ats-global-system-external/src/web.config",
              "projects/ats-global-system-external/src/config.ts",
              {
                "glob": "**/*",
                "input": "node_modules/ngx-extended-pdf-viewer/assets/",
                "output": "/assets/"
              },
              {
                "glob": "**/*",
                "input": "projects/ats-lib/src/assets",
                "output": "/assets-lib/"
              },
              {
                "glob": "**/*",
                "input": "node_modules/ngx-extended-pdf-viewer/bleeding-edge/",
                "output": "/bleeding-edge/"
              }
            ],
            "styles": [
              "./node_modules/bootstrap/dist/css/bootstrap.min.css",
               "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",       
              "./node_modules/@angular/material/legacy-prebuilt-themes/legacy-indigo-pink.css",
              "./node_modules/font-awesome/css/font-awesome.css",
              "projects/ats-global-system-external/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "10mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/ats-global-system-external/src/environments/environment.ts",
                  "with": "projects/ats-global-system-external/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              }
            },
            "testing": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "10mb",
                  "maximumError": "15mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/ats-global-system-external/src/environments/environment.ts",
                  "with": "projects/ats-global-system-external/src/environments/environment.qa.ts"
                }
              ],
              "outputHashing": "all"
            },
            "staging": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/ats-global-system-external/src/environments/environment.ts",
                  "with": "projects/ats-global-system-external/src/environments/environment.uat.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "ats-global-system-external:build:production"
            },
            "testing": {
              "browserTarget": "ats-global-system-external:build:testing"
            },
            "staging": {
              "browserTarget": "ats-global-system-external:build:staging"
            },
            "development": {
              "browserTarget": "ats-global-system-external:build:development",
              "port": 8400
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "ats-global-system-external:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/ats-global-system-external/src/test.ts",
            "polyfills": "projects/ats-global-system-external/src/polyfills.ts",
            "tsConfig": "projects/ats-global-system-external/tsconfig.spec.json",
            "karmaConfig": "projects/ats-global-system-external/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/ats-global-system-external/src/favicon.ico",
              "projects/ats-global-system-external/src/assets"
            ],
            "styles": [
              "projects/ats-global-system-external/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    },
    "ats-lib": {
      "projectType": "library",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/ats-lib",
      "sourceRoot": "projects/ats-lib/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/ats-lib/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ats-lib/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ats-lib/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/ats-lib/src/test.ts",
            "tsConfig": "projects/ats-lib/tsconfig.spec.json",
            "karmaConfig": "projects/ats-lib/karma.conf.js"
          }
        }
      }
    }
  }
}
